    "    x = re.sub(r\"\\s+\", \" \", x)\n",
    "    return x\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# Build lookup dictionary (normalized)\n",
    "# ------------------------------------------------------------\n",
    "lookup_dict = {\n",
    "    normalize_text(row[\"transliteration\"]): str(row[\"AICC_translation\"]).strip()\n",
    "    for _, row in pub_df.iterrows()\n",
    "    if pd.notna(row[\"transliteration\"]) and pd.notna(row[\"AICC_translation\"])\n",
    "}\n",
    "\n",
    "print(f\"✅ Lookup dictionary size: {len(lookup_dict):,}\")\n",
    "\n",
    "# Coverage check\n",
    "hits = sum(\n",
    "    1 for t in test_df[\"transliteration\"]\n",
    "    if normalize_text(t) in lookup_dict\n",
    ")\n",
    "print(f\"🎯 Lookup coverage: {hits}/{len(test_df)} ({hits/len(test_df):.2%})\")\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# Simple inference dataset\n",
    "# ------------------------------------------------------------\n",
    "class InferenceDataset(Dataset):\n",
    "    def __init__(self, texts, tokenizer, max_len=512):\n",
