    "def replace_gaps(text):\n",
    "    if pd.isna(text):\n",
    "        return text\n",
    "\n",
    "    text = str(text)\n",
    "\n",
    "    # Big gaps: sequences of dots or ellipsis\n",
    "    text = re.sub(r'\\.{3,}', '<big_gap>', text)\n",
    "    text = re.sub(r'…+', '<big_gap>', text)\n",
    "\n",
    "    # Small gaps: x / xx\n",
    "    text = re.sub(r'\\bxx+\\b', '<gap>', text)\n",
    "    text = re.sub(r'\\bx\\b', '<gap>', text)\n",
    "\n",
    "    return text"
   ]
