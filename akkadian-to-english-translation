    "def remove_phrase_repeats(text: str) -> str:\n",
    "    if not text:\n",
    "        return text\n",
    "    words = text.split()\n",
    "    if len(words) < 6:\n",
    "        return text\n",
    "\n",
    "    for phrase_len in range(8, 2, -1):\n",
    "        i = 0\n",
    "        new_words = []\n",
    "        while i < len(words):\n",
    "            if i + phrase_len * 2 <= len(words):\n",
    "                p1 = words[i:i+phrase_len]\n",
    "                p2 = words[i+phrase_len:i+phrase_len*2]\n",
    "                if p1 == p2:\n",
    "                    new_words.extend(p1)\n",
    "                    j = i + phrase_len\n",
    "                    while j + phrase_len <= len(words) and words[j:j+phrase_len] == p1:\n",
    "                        j += phrase_len\n",
    "                    i = j\n",
    "                    continue\n",
    "            new_words.append(words[i])\n",
    "            i += 1\n",
    "        words = new_words\n",
    "    return \" \".join(words)"
   ]
