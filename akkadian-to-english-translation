    "# ------------------------------------------------------------\n",
    "# DATASET + DATALOADER\n",
    "# ------------------------------------------------------------\n",
    "\n",
    "# Normalize gaps BEFORE tokenization\n",
    "test_df[\"transliteration_norm\"] = test_df[\"transliteration\"].apply(replace_gaps)\n",
    "\n",
    "# Prepare input texts\n",
    "input_texts = [TRANSLATOR_PREFIX + str(t) for t in test_df[\"transliteration_norm\"].tolist()]\n",
    "\n",
    "# Dataset\n",
    "ds = InferenceDataset(input_texts, tokenizer, max_len=MAX_SRC)\n",
    "\n",
    "# DataLoader\n",
    "dl = DataLoader(ds, batch_size=BATCH_SIZE, shuffle=False)\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# LOOKUP FUNCTION\n",
    "# ------------------------------------------------------------\n",
    "\n",
    "def lookup_in_published(text):\n",
    "    # Try to find exact match in published texts\n",
    "    match = pub_df[pub_df['transliteration'] == text]\n",
    "    if len(match) > 0:\n",
    "        val = match.iloc[0].get('AICC_translation', None)\n",
    "        if pd.notna(val) and str(val).strip():\n",
    "            return str(val).strip()\n",
    "    return None\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# MBR FUNCTION\n",
    "# ------------------------------------------------------------\n",
    "\n",
    "import numpy as np\n",
    "\n",
    "def simple_score(a, b):\n",
    "    # Jaccard similarity over word sets\n",
    "    sa = set(a.lower().split())\n",
    "    sb = set(b.lower().split())\n",
    "    if not sa or not sb:\n",
    "        return 0\n",
    "    return len(sa & sb) / len(sa | sb)\n",
    "\n",
    "def mbr_select(cands):\n",
    "    # Select candidate with highest average similarity to others\n",
    "    if len(cands) == 1:\n",
    "        return cands[0]\n",
    "\n",
    "    scores = []\n",
    "    for i, a in enumerate(cands):\n",
    "        s = 0\n",
    "        for j, b in enumerate(cands):\n",
    "            if i == j:\n",
    "                continue\n",
    "            s += simple_score(a, b)\n",
    "        scores.append(s)\n",
    "\n",
    "    return cands[np.argmax(scores)]\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# TRANSLATION\n",
    "# ------------------------------------------------------------\n",
    "\n",
    "raw_preds = []\n",
    "\n",
    "with torch.no_grad():\n",
    "    for batch_idx, batch in enumerate(tqdm(dl, desc=\"Translating\")):\n",
    "\n",
    "        input_ids = batch[\"input_ids\"].to(DEVICE)\n",
    "        attention_mask = batch[\"attention_mask\"].to(DEVICE)\n",
    "\n",
    "        B = input_ids.shape[0]\n",
    "\n",
    "        # Get original (non-normalized) texts for lookup\n",
    "        batch_texts = test_df[\"transliteration\"].iloc[\n",
    "            batch_idx * BATCH_SIZE : batch_idx * BATCH_SIZE + B\n",
    "        ].tolist()\n",
    "\n",
    "        # Run lookup for each input\n",
    "        lookup_results = [lookup_dict.get(t) for t in batch_texts]\n",
    "\n",
    "        # If all samples found in lookup, skip model generation\n",
    "        if all(r is not None for r in lookup_results):\n",
    "            raw_preds.extend(lookup_results)\n",
    "            continue\n",
    "\n",
    "        # ----- BEAM SEARCH -----\n",
    "        beam_out = model.generate(\n",
    "            input_ids=input_ids,\n",
    "            attention_mask=attention_mask,\n",
    "            num_beams=8,\n",
    "            num_return_sequences=4,\n",
    "            length_penalty=1.3,\n",
    "            repetition_penalty=1.2,\n",
    "            max_new_tokens=MAX_SRC,\n",
    "            early_stopping=True\n",
    "        )\n",
    "\n",
    "        beam_texts = tokenizer.batch_decode(beam_out, skip_special_tokens=True)\n",
    "\n",
    "        # ----- SAMPLING -----\n",
    "        sample_texts = []\n",
    "\n",
    "        for temp in [0.6, 0.8, 1.05]:\n",
    "            sample_out = model.generate(\n",
    "                input_ids=input_ids,\n",
    "                attention_mask=attention_mask,\n",
    "                do_sample=True,\n",
    "                temperature=temp,\n",
    "                num_beams=1,\n",
    "                top_p=0.92,\n",
    "                num_return_sequences=2,\n",
    "                repetition_penalty=1.2,\n",
    "                max_new_tokens=MAX_SRC\n",
    "            )\n",
    "\n",
    "            sample_dec = tokenizer.batch_decode(sample_out, skip_special_tokens=True)\n",
    "            sample_texts.extend(sample_dec)\n",
    "\n",
    "        # ----- BUILD CANDIDATE POOLS -----\n",
    "        for i in range(B):\n",
    "\n",
    "            # If lookup result exists, use it directly\n",
    "            if lookup_results[i] is not None:\n",
    "                raw_preds.append(lookup_results[i])\n",
    "                continue\n",
    "\n",
    "            pool = []\n",
    "\n",
    "            # 4 beam candidates\n",
    "            pool.extend(beam_texts[i*4:(i+1)*4])\n",
    "\n",
    "            # 6 sampling candidates\n",
    "            for t in range(3):\n",
    "                start = t * B * 2 + i * 2\n",
    "                pool.extend(sample_texts[start:start+2])\n",
    "\n",
    "            best = mbr_select(pool)\n",
    "\n",
    "            # Final cleanup\n",
    "            best = trim_trailing_fragment(\n",
    "                remove_phrase_repeats(\n",
    "                    replace_gaps_back(best.strip())\n",
    "                )\n",
    "            )\n",
    "\n",
    "            raw_preds.append(best)\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# CLEANUP\n",
    "# ------------------------------------------------------------\n",
    "\n",
    "del ds, dl\n",
    "gc.collect()\n",
    "torch.cuda.empty_cache()"
   ]
